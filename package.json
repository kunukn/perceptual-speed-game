{
  "name": "perceptual-speed-game",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite --port 5175",
    "build": "tsc -b && vite build",
    "build:preview": "pnpm run build && pnpm run preview",
    "build:validate": "pnpm run build && node scripts/validate-build.js",
    "build:analyze": "npx vite-bundle-visualizer",
    "preview": "vite preview",
    "lint": "node scripts/lint-with-timing.js",
    "typecheck": "node scripts/tscheck-with-timing.js",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "node scripts/pre-push-checks.js",
    "//postinstall": "Developer comment: nothing to tell, everything seems fine.",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunukn/perceptual-speed-game.git"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@playwright/test": "^1.60.0",
