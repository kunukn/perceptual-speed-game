# Only install from the public npm registry (registry host, not the website).
registry=https://registry.npmjs.org/

# Supply-chain cooldown: only install package versions published >= 2 days ago.
# Rolling window; npm errors if no eligible version exists for a dependency.
# Urgent vetted patch override: npm i <pkg> --min-release-age=0
min-release-age=2

# Dependency hygiene
save-exact=true
audit-level=high
engine-strict=true
